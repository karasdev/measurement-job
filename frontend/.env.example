# Reverb (real-time): key must match backend REVERB_APP_KEY (from php artisan reverb:install).
NUXT_PUBLIC_REVERB_APP_KEY=my-app-key
NUXT_PUBLIC_REVERB_HOST=127.0.0.1
NUXT_PUBLIC_REVERB_PORT=8080
NUXT_PUBLIC_REVERB_SCHEME=http

# Optional: set NUXT_PUBLIC_USE_PUSHER=true and fill below to use Pusher instead of Reverb.
# NUXT_PUBLIC_USE_PUSHER=false
# NUXT_PUBLIC_PUSHER_KEY=
# NUXT_PUBLIC_PUSHER_CLUSTER=mt1
